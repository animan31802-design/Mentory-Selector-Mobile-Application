        <activity
            android:name=".StaffAdvisorAlter"
            android:exported="true" >
        </activity>
        <activity
            android:name=".FacultyAlter"
            android:exported="true" >
        </activity>
        <activity
            android:name=".RandomPicker"
            android:exported="true" >
        </activity>
        <activity
            android:name=".StaffAdvisor"
            android:exported="true" >
        </activity>
        <activity
            android:name=".Admin"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>